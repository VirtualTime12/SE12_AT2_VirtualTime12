-- ("Tokoyami Towa", "Gen 4", "Japan", "January 3, 2020", "A young devil who is visiting human society to gain experience and develop her skills. But instead of studying, she became addicted to video games! After learning about a tool for communicating with humans called 'streaming', she's trying it out to help with her studies.", "August 8", 150, "https://hololive.hololivepro.com/wp-content/uploads/2020/06/Tokoyami-Towa_pr-img_01.png", "https://www.youtube.com/channel/UC1uv2Oq6kNxgATlCiez59hw", "https://hololive.hololivepro.com/en/talents/tokoyami-towa/", FALSE, "https://yt3.googleusercontent.com/FF7U-8fSNFmZalS5rOz0xblWY-wNC_IxZZ4AG_BctbqptVxfIAhNrn-6E3MYNCH33EgcASGJ=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Tsunomaki Watame", "Gen 4", "Japan", "December 29, 2019", "Loves singing, and as she continued uploading song covers and having weekly singing streams titled 'Watameh Night Fever!!', she started wanting to stand on Tokyo Budokan's stage someday. Make sure you check out her Tsunomaki Rock Paper Scissors videos as well!", "June 6", 151, "https://hololive.hololivepro.com/wp-content/uploads/2020/06/Tsunomaki-Watame_pr-img_01.png","https://www.youtube.com/channel/UCqm3BQLlJfvkTsX_hvm0UmA", "https://hololive.hololivepro.com/en/talents/tsunomaki-watame/", FALSE, "https://yt3.googleusercontent.com/qayRHMxLu8da1JWWG9B7km4vvFZU56OqXiKfHfHJlHJkOuaxG2mDZMNnT4Y7rD5Bx2E6pPP4lDk=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj");

-- JP GEN 5
-- INSERT INTO vtubers(name, generation, branch, debut_date, description, birthday, height, img_url, youtube, hololive_url, graduated, banner_url)
-- VALUES ("Shishiro Botan", "Gen 5", "Japan", "August 14, 2020", "Contrary to her sporty appearance, she's a white lion who prefers lazing around. Despite her typically hands-off attitude, once she has made up her mind she will always follow through to the end. Her favorite phrase is 'Wealth isn't measured with money.' Born in a rough neighborhood, she's a bit of a gaming addict. She's the type to set aside powerful heals even at the end game.", "September 8", 166, "https://hololive.hololivepro.com/wp-content/uploads/2024/05/Shishiro-Botan_pr-img_01.png", "https://www.youtube.com/channel/UCUKD-uaobj9jiqB-VXt71mA", "https://hololive.hololivepro.com/en/talents/shishiro-botan/", FALSE, "https://yt3.googleusercontent.com/h2U0OUQ6wVPh0it2H8HRDmcdprY76zjXrAhzE9dj6N9YOlK1pMxQfEkrP1xRNOj1LPaX-Mutwg=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Yukihana Lamy", "Gen 5", "Japan", "August 12, 2020", "The daughter of a noble snow family living in the vast, white, icy lands far from civilization. Struck by the smiles and vibrant live streams by the talents from hololive, she burst out of the comforts of her home with her companion, Daifuku. Her serious facade belies her clueless and empty-headed side of her.", "November 15", 158, "https://hololive.hololivepro.com/wp-content/uploads/2020/06/Yukihana-Lamy_pr-img_01.png", "https://www.youtube.com/channel/UCFKOVgVbGmX65RxO3EtH3iw", "https://hololive.hololivepro.com/en/talents/yukihana-lamy/", FALSE, "https://yt3.googleusercontent.com/1SNBEexEQA6bnlXOFAt9QNNfCL-NYLxGN66hTlleO-UyEQeixme1HdNM_Q_RE159VcyQ9iPw8A=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Momosuzu Nene", "Gen 5", "Japan", "August 13, 2020", "A girl who came from another world in order to become an idol. She loves singing and dancing, and drawing. She is training hard every day to become someone loved by many.", "March 2", 159, "https://hololive.hololivepro.com/wp-content/uploads/2020/06/Momosuzu-Nene_pr-img_01.png", "https://www.youtube.com/channel/UCAWSyEs_Io8MtpY3m-zqILA", "https://hololive.hololivepro.com/en/talents/momosuzu-nene/", FALSE, "https://yt3.googleusercontent.com/IaLFgTIY4y0J3IIAc9o8YDwF2rNrfVE5MAAdue9u-Pc0pef7OStvgKxVivyLXXoEz5sPZygaySQ=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Omaru Polka", "Gen 5", "Japan", "August 16, 2020", "A circus performer who joined hololive in hopes of becoming the ringmaster of the VTuber world. She enjoys wowing audiences with acrobatics, and she lives by the words, 'When you've decided you're gonna do something, follow through!' Her natural charm glosses over her occasional mess-ups.", "January 30", 153, "https://hololive.hololivepro.com/wp-content/uploads/2024/12/Omaru-Polka_pr-img_01.png", "https://www.youtube.com/channel/UCK9V2B22uJYu3N7eR_BT9QA", "https://hololive.hololivepro.com/en/talents/omaru-polka/", FALSE, "https://yt3.googleusercontent.com/EP1u-nLVWBd7baERapt2e_-iI4YVl1wCukSEmw0FP2CJFompE-7TtSlxG0uKk2oT5Kn8l54g1w=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj");

-- JP holoX
-- INSERT INTO vtubers(name, generation, branch, debut_date, description, birthday, height, img_url, youtube, hololive_url, graduated, banner_url)
-- VALUES ("Sakamata Chloe", "holoX", "Japan", "November 29, 2021", "An intern who acts as a fixer and cleaner for Secret Society holoX. Calm and composed at all times, she carries out her orders without so much as batting an eyelid. She loves music and can be found listening to it every chance she gets. And while she denies it vehemently, she apparently tends to come across as guarded and not very upfront with her thoughts, only letting people get very occasional glimpses into how she really feels.", "May 18", 148, "https://hololive.hololivepro.com/wp-content/uploads/2024/09/Sakamata-Chloe_pr-img_01.png", "https://www.youtube.com/channel/UCIBY1ollUsauvVi4hW4cumw", "https://hololive.hololivepro.com/en/talents/sakamata-chloe/", TRUE, "https://yt3.googleusercontent.com/SqeeKUiKq_tKkTrSkjveZr1OeZpScMzHE21XW799g9R7m4ia8ost8hSGylFL5A_j1w-_n6yUdw=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("La+ Darkness", "holoX", "Japan", "November 26, 2021", "The one who established Secret Society holoX. She was originally known for her vast power and intelligence, but most of it is now sealed away. She is vaguely aware of the debilitating nature of her shackles but does not remember when or how they got there.", "May 25", 139, "https://hololive.hololivepro.com/wp-content/uploads/2020/07/La-Darknesss_pr-img_01.png", "https://www.youtube.com/channel/UCENwRMx5Yh42zWpzURebzTw", "https://hololive.hololivepro.com/en/talents/la-darknesss/", FALSE, "https://yt3.googleusercontent.com/VIBQZXSxxqQyKF76sHZlIWDrxlVbd-zmJWHkbBKjXLNY7eCJcv0bS7RSr4Aw3hVz5kD8Q0gyOA=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Kazama Iroha", "holoX", "Japan", "November 30, 2021", "Secret Society holoX's insurance policy. Hailing from a remote mountainous area, she left her home behind and, along with her companion, set off on a journey to achieve her dream of seeing and learning more about the outside world. Nowadays, she handles security detail and bodyguard missions for holoX, making enough money to get by.", "June 18", 156, "https://hololive.hololivepro.com/wp-content/uploads/2020/07/Kazama-Iroha_pr-img_01.png", "https://www.youtube.com/channel/UC_vMYWcDjmfdpH6r4TTn1MQ", "https://hololive.hololivepro.com/en/talents/kazama-iroha/", FALSE, "https://yt3.googleusercontent.com/463BQdwrff-GKTT3iO3xc6RaNtSRzx5azhDVC7sf9rXN9sRS3nVe6gICEZrXX0NUffMuJG8nQPk=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Hakui Koyori", "holoX", "Japan", "November 28, 2021", "The one in charge of R&D in Secret Society holoX. As part of her studies into human behavior, she meddles in the other members' affairs and tries to help them out at every turn. Possessed by an insatiable thirst for knowledge, she may sometimes also deliberately mess with people just to see how they react. The self-proclaimed 'brains of the operation'. Her areas of expertise, however, are pretty limited.", "March 15", 153, "https://hololive.hololivepro.com/wp-content/uploads/2020/07/Hakui-Koyori_pr-img_01.png", "https://www.youtube.com/channel/UC6eWCld0KwmyHFbAqK3V-Rw", "https://hololive.hololivepro.com/en/talents/hakui-koyori/", FALSE, "https://yt3.googleusercontent.com/vNCRYP8INcAEM3Z85s1UmVMaZ1lvD0FF1ID0sC61bkCPhLqB8zv9d3-UysiE3UcgMMLEk2qGEXU=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Takane Lui", "holoX", "Japan", "November 27, 2021", "The executive officer of Secret Society holoX. As holoX's point of contact and the one in charge of external affairs, she is the de facto leader of the group, handling matters that the founder cannot. While she may seem aloof and standoffish at first glance, she is a compassionate person who cares a lot for her subordinates. Unfortunately, she is also rather prone to screwing up in crucial moments.", "June 11", 161, "https://hololive.hololivepro.com/wp-content/uploads/2024/08/Takane-Lui_pr-img_01.png", "https://www.youtube.com/channel/UCs9_O1tRPMQTHQ-N_L6FU2g", "https://hololive.hololivepro.com/en/talents/takane-lui/", FALSE, "https://yt3.googleusercontent.com/4gkDXbZRFyPeKst-oi3XCAe5yd6_ZvcIszJCZk17dBYe1eWIS9sy1vJxs1bsaBJYfzdTclPP=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj");

-- JP ReGLOSS
-- INSERT INTO vtubers(name, generation, branch, debut_date, description, birthday, height, img_url, youtube, hololive_url, graduated, banner_url)
-- VALUES ("Hiodoshi Ao", "ReGLOSS", "Japan", "September 9, 2023", "A manga artist who loves solitude... or so the people around her think. She tries to play herself off as cool and aloof, but beyond the surface she is quite the otaku. She cares a lot about how she is perceived, which is why she is always dressed immaculately in public. How she is at home, though... is a Pandora's box.", "February 27", 171, "https://hololive.hololivepro.com/wp-content/uploads/2023/09/Hiodoshi-Ao_pr-img_01_a.png", "https://www.youtube.com/channel/UCMGfV7TVTmHhEErVJg1oHBQ", "https://hololive.hololivepro.com/en/talents/hiodoshi-ao/", TRUE, "https://nichegamer.com/wp-content/uploads/2025/02/hiodoshi-ao-2-10-2025-1-1536x864.jpg"),
-- ("Todoroki Hajime", "ReGLOSS", "Japan", "September 10, 2023", "A jane-of-all-trades seeking to be the #1 badass in the universe. Why the universe? Why 'badass'? Nobody knows. She's the restless sort and, to no surprise, enjoys physical activities. Also to no surprise, she's not good with tools and equipment, meaning she's a disaster-class in cooking. Her trusty partner Banpen teaches her every day about how to be a badass.", "June 7", 155, "https://hololive.hololivepro.com/wp-content/uploads/2023/09/Todoroki-Hajime_pr-img_01_a.png", "https://www.youtube.com/@TodorokiHajime", "https://hololive.hololivepro.com/en/talents/todoroki-hajime/", FALSE, "https://s1.zerochan.net/Todoroki.Hajime.600.4587748.jpg"),
-- ("Otonose Kanade", "ReGLOSS", "Japan", "September 9, 2023", "An aspiring musician, whose life also has ups and downs like a crescendo. Music is always by her side. She wears her heart on her sleeve and is capable of putting incredible amounts of effort into the things she enjoys. On the other hand, anything she dislikes immediately puts a frown on her face, showing she still retains a childish side. However, she can be bribed with good food...", "April 20", 153, "https://hololive.hololivepro.com/wp-content/uploads/2023/09/Otonose-Kanade_pr-img_01_a.png", "https://www.youtube.com/@OtonoseKanade", "https://hololive.hololivepro.com/en/talents/otonose-kanade/", FALSE, "https://s1.zerochan.net/Otonose.Kanade.600.4579944.jpg"),
-- ("Juufuutei Raden", "ReGLOSS", "Japan", "September 10, 2023", "A grandma's girl who covers herself in both tradition and revolution, and sees big dreams in the rakugo world. She loves arts and culture of all kinds—new and old, Eastern and Western. She visits museums so often that she is left penny-pinching the rest of the time. It is most certainly not due to her frequent purchases of alcohol. Through her encounter with rakugo, she has come to enjoy public speaking more than ever, and she is fervishly writing up her own skits.", "February 4", 159, "https://hololive.hololivepro.com/wp-content/uploads/2023/09/Juufuutei-Raden_pr-img_01_a.png", "https://www.youtube.com/@JuufuuteiRaden", "https://hololive.hololivepro.com/en/talents/juufuutei-raden/", FALSE, "https://preview.redd.it/juufuutei-raden-1st-birthday-3d-live-it-was-fate-that-we-v0-j7yhuoath3he1.jpeg?width=1080&crop=smart&auto=webp&s=35aed3aee582a8bb609819f25826804ad463fcde"),
-- ("Ichijou Ririka", "ReGLOSS", "Japan", "September 9, 2023", "An enterprising entrepreneur on the up-and-up. She started her company on a complete whim, but things seem to be going well so far. She has excellent people skills and is an excellent communicator, which allows her to handle transactions with foreign companies by herself. Her secret to success is a good night's sleep. Meanwhile, she has quite the unruly side when it comes to her private life, and she can be quite lacking when it comes to chores around the home.", "May 12", 162, "https://hololive.hololivepro.com/wp-content/uploads/2023/09/Ichijou-Ririka_pr-img_01_a.png", "https://www.youtube.com/@IchijouRirika", "https://hololive.hololivepro.com/en/talents/ichijou-ririka/", FALSE, "https://i.ytimg.com/vi/rGIjxzCpYrY/maxresdefault.jpg");

-- JP FLOW GLOW
-- INSERT INTO vtubers(name, generation, branch, debut_date, description, birthday, height, img_url, youtube, hololive_url, graduated, banner_url)
-- VALUES ("Rindo Chihaya", "FLOW GLOW", "Japan", "November 9, 2024", "The DJ and Driver of FLOW GLOW. A self-proclaimed driver with 300 horsepower, nobody can put a brake on her when she talks and sings. Though still a newbie at DJ-ing, her earnestness, combined with the curiosity that she inherited from her brother, will make her a full-fledged DJ in no time. The thing most important to her right now is going for a spin with her buddies on her beloved car.", "July 8", 168, "https://hololive.hololivepro.com/wp-content/uploads/2023/09/Rindo-Chihaya_pr-img_01_a.png", "https://www.youtube.com/channel/UCKMWFR6lAstLa7Vbf5dH7ig", "https://hololive.hololivepro.com/en/talents/rindo-chihaya/", FALSE, "https://yt3.googleusercontent.com/6zeu9LBfch4o940kNvgBLKBPzmHlAg2rImOclLmeFcM9_J68GkLk2Gx6LMBDJhvIhc_R33t6oPk=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Koganei Niko", "FLOW GLOW", "Japan", "November 9, 2024", "The jokester of FLOW GLOW. With a strong passion, she's willing to give even her life to see people smile. Bulldozing her way through? Breaking out of character? That's all G if it ends with laughter. Weak against animals and mornings, her every day starts by getting out of bed with a fuzzy head and hair as she prepares breakfast for her cat.", "July 25", 172, "https://hololive.hololivepro.com/wp-content/uploads/2023/09/Koganei-Niko_pr-img_01_a.png", "https://www.youtube.com/channel/UCuI_opAVX6qbxZY-a-AxFuQ", "https://hololive.hololivepro.com/en/talents/koganei-niko/", FALSE, "https://yt3.googleusercontent.com/If9aCx40rDmjZvnbZwzJZ40YR1k9tFzwOuq1ozbpn0RdW9XtBld7_MblDMmMHWzZU4r_NRDLwdA=w2120-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Isaki Riona", "FLOW GLOW", "Japan", "November 9, 2024", "The leader of FLOW GLOW. Extremely stoic and hates losing with a passion. She puts on a poker face so as not to be looked down upon, but her heart melts when she sees little animals and spoils them rotten. As a vivid fan of Shonen manga, she can be quite the passionate figure contrary to her cool-headed facade.", "May 29", 160, "https://hololive.hololivepro.com/wp-content/uploads/2023/09/Isaki-Riona_pr-img_01_a.png", "https://www.youtube.com/channel/UC9LSiN9hXI55svYEBrrK-tw", "https://hololive.hololivepro.com/en/talents/isaki-riona/", FALSE, "https://yt3.googleusercontent.com/dbbNztNjuw_czY4jLlucj5zngSUl121soCOM8llWgR1VxsGtQjWOXNvRRamWr47JkW1we6seUg=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Mizumiya Su", "FLOW GLOW", "Japan", "November 9, 2024", "The publicity manager of FLOW GLOW. Determined to gain love and praise, she posts regularly on social media with her mouth full of delicacies. Just when she wished the world was a less daunting place, fate led her to the friends she has now. Guess not all hope is lost, is it? Thank you gods. Now, while you're at it, please make her a little bit taller.", "June 16", 145, "https://hololive.hololivepro.com/wp-content/uploads/2023/09/Mizumiya-Su_pr-img_01_a.png", "https://www.youtube.com/channel/UCjk2nKmHzgH5Xy-C5qYRd5A", "https://hololive.hololivepro.com/en/talents/mizumiya-su/", FALSE, "https://yt3.googleusercontent.com/pms6909_V_v3dInYbMbmQ9p7lircEbyD5AZkArB5ip1T9Lvt4cx3boUhneuNFuGp-JhW9tWl=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Kikirara Vivi", "FLOW GLOW", "Japan", "November 9, 2024", "The makeup artist of FLOW GLOW. A seeker of true beauty, always on the lookout for that special item for that extra glow-up. She's not someone who hides expressions from her face; at times, frank words tinged with her dialect spill from her mouth. Her natural enemy is exposure to direct sunlight. Being an indoor person is probably her secret to clear skin.", "August 27", 161, "https://hololive.hololivepro.com/wp-content/uploads/2023/09/Kikirara-Vivi_pr-img_01_a.png", "https://www.youtube.com/channel/UCGzTVXqMQHa4AgJVJIVvtDQ", "https://hololive.hololivepro.com/en/talents/kikirara-vivi/", FALSE, "https://yt3.googleusercontent.com/k1vCsIbtcRaU9OwygWrxTpMWhbsqQO0qC0wm0X31nBYmkbwmqG3TAt1HdM3Z4JWc5YqGz2mLZ84=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj");

-- EN Myth (Gen 1)
-- INSERT INTO vtubers(name, generation, branch, debut_date, description, birthday, height, img_url, youtube, hololive_url, graduated, banner_url)
-- VALUES ("Watson Amelia", "Myth", "English", "September 13, 2020", "Amelia heard strange rumors online surrounding hololive: talking foxes, magical squirrels, superhuman dogs, and more. Soon after beginning her investigation on hololive, and just out of interest, she decided to become an idol herself! She loves to pass her time training her reflexes with FPS games, and challenging herself with puzzle games. 'It's elementary, right?'", "January 6", 150, "https://hololive.hololivepro.com/wp-content/uploads/2020/07/Watson-Amelia_pr-img_01.png", "https://www.youtube.com/channel/UCyl1z3jo3XHR1riLFKG5UAg", "https://hololive.hololivepro.com/en/talents/watson-amelia/", TRUE, "https://yt3.googleusercontent.com/HTXKroTxsR35HOnBe68sD-4ACl2KkdWrxHAhwvl6PWHM7wrZ5JaFdBmX9ExU9dwKRYaLdvoFVw=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Mori Calliope", "Myth", "English", "September 12, 2020", "The Grim Reaper's first apprentice. Due to modern medical care causing a decline in the reaping business, Calliope decided to become a VTuber to harvest souls instead. It seems that the ascended souls of the people who are vaporized by the wholesome interactions between VTubers go to her as well. That being said, despite the image her hardcore vocals and manner of speech gives off, she's actually a gentle-hearted girl who cares greatly for her friends.", "April 4", 167, "https://hololive.hololivepro.com/wp-content/uploads/2020/07/Mori-Calliope_pr-img_01.png", "https://www.youtube.com/channel/UCL_qhgtOy0dy1Agp8vkySQg", "https://hololive.hololivepro.com/en/talents/mori-calliope/", FALSE, "https://yt3.googleusercontent.com/DGxFo_MRkSKiKwcveoBXlo3UHNMwiHySQ9JKrG3vTIk60nusxwmiUhhfDjs8_TDOWGcApd8iJQ=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Gawr Gura", "Myth", "English", "September 13, 2020", "A descendant of the Lost City of Atlantis, who swam to Earth while saying, 'It's so boring down there LOLOLOL!' Gura bought her clothes (and her shark hat) in the human world and she really loves them. In her spare time, she enjoys talking to marine life.", "June 20", 141, "https://hololive.hololivepro.com/wp-content/uploads/2024/05/Gawr-Gura_pr-img_01.png", "https://www.youtube.com/channel/UCoSrY_IQQVpmIRZ9Xf-y93g", "https://hololive.hololivepro.com/en/talents/gawr-gura/", TRUE, "https://yt3.googleusercontent.com/Bz45tSPxypl0WEJVEO06O5fm2H6J38wsA8gHC_if7LcYePqvLbME-z-jvJK8-SC7p2g2FSDC=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Ninomae Ina'nis", "Myth", "English", "September 13, 2020", "Despite her looks, Ina'nis is actually a priestess of the Ancient Ones. One day, she picked up a strange book and then started to gain the power of controlling tentacles. To her, tentacles are just a part in her ordinary life; it has never been a big deal for her. However, her girly mind does want to get them dressed up and stay pretty. After gaining power, she started hearing Ancient Whispers and Revelations. Hence, she began her VTuber activities to deliver random sanity checks on humanity, as an ordinary girl.", "May 20", 157, "https://hololive.hololivepro.com/wp-content/uploads/2020/07/Ninomae-Inanis_pr-img_01.png", "https://www.youtube.com/channel/UCMwGHR0BTZuLsmjY_NT5Pwg", "https://hololive.hololivepro.com/en/talents/ninomae-inanis/", FALSE, "https://images3.alphacoders.com/125/1251757.jpg"),
-- ("Takanashi Kiara", "Myth", "English", "September 12, 2020", "An idol whose dream is to become the owner of a fast food chain. Kiara is a phoenix, not a chicken or turkey. (Very important) She burns brightly, working herself to the bone since she'll just be reborn from her ashes anyway.", "July 6", 165, "https://hololive.hololivepro.com/wp-content/uploads/2020/07/Takanashi-Kiara_pr-img_01.png", "https://www.youtube.com/channel/UCHsx4Hqa-1ORjQTh9TYDhww", "https://hololive.hololivepro.com/en/talents/takanashi-kiara/", FALSE, "https://static-cdn.jtvnw.net/jtv_user_pictures/95350035-30df-47fa-8ca2-4f8c521b231b-profile_banner-480.jpeg");

-- EN Promise (Gen 2)
-- INSERT INTO vtubers(name, generation, branch, debut_date, description, birthday, height, img_url, youtube, hololive_url, graduated, banner_url)
-- VALUES ("Hakos Baelz", "Promise", "English", "August 23, 2021", "Chaos. Mayhem. Entropy..... All in the form of a cute little rat. She is a performer looking for her next stage. Occassionally she will get swept up in her own storm, but thats just part of the fun.", "February 29", 149, "https://hololive.hololivepro.com/wp-content/uploads/2020/07/Hakos-Baelz_pr-img_01.png", "https://www.youtube.com/channel/UCgmPnx-EEeOrZSg5Tiw7ZRQ", "https://hololive.hololivepro.com/en/talents/hakos-baelz/", FALSE, "https://cdn.quavergame.com/mapsets/17918.jpg?v=2e1ccfb61728d3a4c868d9252d0b8208"),
-- ("Ceres Fauna", "Promise", "English", "August 23, 2021", "The Keeper of Nature, a druidic kirin who appeared on the internet to win over humans and convince them to return to nature. She'll attempt to charm you with her soft voice, comforting presence, and surprisingly deep knowledge of cursed memes, but be wary, because she has a reputation for turning people into trees. Once you enter her forest, you won't want to leave.", "March 21", 164, "https://hololive.hololivepro.com/wp-content/uploads/2023/10/Ceres-Fauna_pr-img_01.png", "https://www.youtube.com/channel/UCO_aKKYxn4tvrqPjcTzZ6EQ", "https://hololive.hololivepro.com/en/talents/ceres-fauna/", TRUE, "https://c4.wallpaperflare.com/wallpaper/477/62/529/hololive-english-hololive-anime-girls-virtual-youtuber-ceres-fauna-hd-wallpaper-preview.jpg"),
-- ("IRyS", "Promise", "English", "July 11, 2021", "A Nephilim who was once the embodiment of hope back in 'The Paradise'. While she has left to set off on an adventure, she continues to deliver hope through her lyrics and songs, with determination in her voice. She also bears the precarious and unstable dual nature of a half-demon and half-angel; this phenomenon can be observed on rare occasions, in the form of the most unpredictably yaba—*ahem*, 'surprising', comments from IRyS herself. Bewildering those around her is but another unexpected charm of her duality.", "March 7", 162, "https://hololive.hololivepro.com/wp-content/uploads/2020/07/IRyS_pr-img_01.png", "https://www.youtube.com/channel/UC8rcEBzJSleTkf_-agPM20g", "https://hololive.hololivepro.com/en/talents/irys/", FALSE, "https://pbs.twimg.com/profile_banners/1363705980261855232/1677751177/1080x360"),
-- ("Ouro Kronii", "Promise", "English", "August 23, 2021", "Time is an unwavering, precise entity, and its Warden - its overseer - is equally cool and impeccable. Occasionally her exquisiteness leads her to decisions and bouts of luck that transcend the understanding of mere mortals. However, even utmost perfection finds no foothold in the face of her mortal enemy—disorder.", "March 14", 168, "https://hololive.hololivepro.com/wp-content/uploads/2020/07/Ouro-Kronii_pr-img_01.webp", "https://www.youtube.com/channel/UCmbs8T6MWqUHP1tIQvSgKrg", "https://hololive.hololivepro.com/en/talents/ouro-kronii/", FALSE, "https://pbs.twimg.com/profile_banners/1409817096523968513/1773463818/1080x360"),
-- ("Nanashi Mumei", "Promise", "English", "August 23, 2021", "The Guardian of Civilization, a traveling owl who has borne witness to numerous events. Even though glimpses of past memories—seen and forgotten throughout her endless journey—occasionally surface, she is now a lovely girl who relishes each and every day. When once she was just an observer, she now enjoys her everyday interactions with civilizations and its people. And soon the ordinary, ever-present daily life, shall also weave itself into the tapestry of civilization.", "August 4", 156, "https://hololive.hololivepro.com/wp-content/uploads/2023/10/Nanashi-Mumei_pr-img_01.png", "https://www.youtube.com/channel/UC3n5uGu18FoCy23ggWWp8tA", "https://hololive.hololivepro.com/en/talents/nanashi-mumei/", TRUE, "https://pbs.twimg.com/media/GpjnebWbgAAGcsP.jpg");


-- EN Advent (Gen 3)
-- INSERT INTO vtubers(name, generation, branch, debut_date, description, birthday, height, img_url, youtube, hololive_url, graduated, banner_url)
-- VALUES ("Fuwawa Abyssgard", "Advent", "English", "July 31, 2023", "The fluffy older twin sister of The Demonic Guard Dogs, who were sealed away in The Cell for being a pain in the godly behind, Fuwawa Abyssgard is 'The Fluffy One'. Her duty is to calmly look after her younger twin sister Mococo and their pet Pero, but that calmness can be short-lived. Ultimately, she is a bouncy and boisterous girl who loves to chat and play.", "February 1", 155, "https://hololive.hololivepro.com/wp-content/uploads/2021/07/Fuwawa-Abyssgard_pr-img_01.png", "https://www.youtube.com/channel/UCt9H_RpQzhxzlyBxFqrdHqA", "https://hololive.hololivepro.com/en/talents/fuwawa-abyssgard/", FALSE, "https://yt3.googleusercontent.com/lmw46V4yJqqgCAsf09Vj0UNjCDvxLhOipv_1wRA_Z7V9t8r0OQ0z4flcWkhOFUOVW0buB9aTQFc=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Mococo Abyssgard", "Advent", "English", "July 31, 2023", "The fuzzy younger twin sister of The Demonic Guard Dogs, who were sealed away in The Cell for being a pain in the godly behind, Mococo Abyssgard is 'The Fuzzy One'. The rambunctious Mococo spent all her time imprisoned watching anime and playing games, often roping her older twin sister Fuwawa and their pet Pero in for more chaotic antics. It's rumored that she took part in the prison break just for the heck of it.", "February 2", 155, "https://hololive.hololivepro.com/wp-content/uploads/2021/07/Mococo-Abyssgard_pr-img_01.png", "https://www.youtube.com/channel/UCt9H_RpQzhxzlyBxFqrdHqA", "https://hololive.hololivepro.com/en/talents/mococo-abyssgard/", FALSE, "https://yt3.googleusercontent.com/lmw46V4yJqqgCAsf09Vj0UNjCDvxLhOipv_1wRA_Z7V9t8r0OQ0z4flcWkhOFUOVW0buB9aTQFc=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Koseki Bijou", "Advent", "English", "July 30, 2023", "Formed from the crystallization of all forms of human emotion, Koseki Bijou is 'The Jewel of Emotions'. Over years and years, emotions of beauty and filth alike have woven into her under immense pressure, resulting in an unmatched brilliance. Her ancient, mystic brilliance caused strife between the masses of the greedy, who fought over ownership of her. This led to her being imprisoned in secrecy, far from the reach of humans. It seems as though when she encounters people, and particularly their good emotions, her radiance shines even brighter.", "April 14", 140, "https://hololive.hololivepro.com/wp-content/uploads/2021/07/Koseki-Bijou_pr-img_01.png", "https://www.youtube.com/channel/UC9p_lqQ0FEDz327Vgf5JwqA", "https://hololive.hololivepro.com/en/talents/koseki-bijou/", FALSE, "https://yt3.googleusercontent.com/zShm3O93N6Ivv09pQbGLa86PjU1WLnUXEXN7ITNlErXScJhkD00cog8lUBSo7t_7NOpYFqukWA=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Nerissa Ravencroft", "Advent", "English", "July 31, 2023", "With a deep love of song, Nerissa Ravencroft is 'The Demon of Sound'. Her powerful love turned into a dark power that inhabited her singing, giving her music the potential to drive the entire world mad. The gods, fearful of her beautiful voice, decided to seal her away for eternity, but this did not seal away her desire to sing for others. While she was sealed away, she came across Japanese otaku culture, and is currently fascinated by idol songs and penlights. Maybe her life imprisoned wasn't all that bad.", "November 21", 175, "https://hololive.hololivepro.com/wp-content/uploads/2021/07/Nerissa-Ravencroft_pr-img_01.webp", "https://www.youtube.com/channel/UC_sFNM0z0MWm9A6WlKPuMMg", "https://hololive.hololivepro.com/en/talents/nerissa-ravencroft/", FALSE, "https://yt3.googleusercontent.com/O8AT2TqQ__ZxIZcr4F5kTBGeEXe-1sdEfVAZX7L7znev8O1gtCqndxHUrGOOycVqZ9W3A9Nb=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Shiori Novella", "Advent", "English", "July 30, 2023", "Driven by her thirst for knowledge, Shiori Novella is 'The Archiver'. She turns her favorite stories and treasured memories into bookmarks and saves them. By misfortune, she was found to have obtained forbidden knowledge within one of her stories and was imprisoned. But to her, that experience itself is but a fascinating story. In order to continue her search for more stories, she planned and executed a prison break.", "May 2", 163, "https://hololive.hololivepro.com/wp-content/uploads/2021/07/Shiori-Novella_pr-img_01.webp", "https://www.youtube.com/channel/UCgnfPPb9JI3e9A4cXHnWbyg", "https://hololive.hololivepro.com/en/talents/shiori-novella/", FALSE, "https://yt3.googleusercontent.com/ZxVUd_igMHK3L8yrZ07icqzCK7BtWRtu1J2DKh6zzGOAHgM50Mb7G73uMF9TmSBUJQgMWAZ9=w2120-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj");

-- EN Justice (Gen 4)
-- INSERT INTO vtubers(name, generation, branch, debut_date, description, birthday, height, img_url, youtube, hololive_url, graduated, banner_url)
-- VALUES ("Elizabeth Rose Bloodflame", "Justice", "English", "June 22, 2024", "The Scarlet Queen, Elizabeth Rose Bloodflame paves the way for the world and all of its people. Not only does she stand at the forefront during missions with her physical prowess, but she also captures the hearts of all around her with her beautiful singing voice. She is highly self-disciplined and a bit too hard on herself, but, perhaps due to her culture's emphasis on politeness and manners, she tends to go a bit soft on those around her. As a result, she spends her days stressed out with her work coordinating Justice, but it seems like there's nothing a nice nap in a comfy bed can't fix.", "April 25", 171, "https://hololive.hololivepro.com/wp-content/uploads/2023/07/Elizabeth-Rose-Bloodflame_pr-img_01.webp", "https://www.youtube.com/channel/UCW5uhrG1eCBYditmhL0Ykjw", "https://hololive.hololivepro.com/en/talents/elizabeth-rose-bloodflame/", FALSE, "https://yt3.googleusercontent.com/wkioFy6NFpeZJi6LkB521yFmJxPhvUvunQyVLkGJqXszKiffPUtfeICzg0ZPxOI_NTHVBdH2dxc=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Cecilia Immergreen", "Justice", "English", "June 23, 2024", "Cecilia Immergreen is an Ancient Automaton, with a penchant for flowers, tea, and creating music. Crafted during ancient times, Cecilia was originally made to be dedicated to eternal servitude. Yet in recent times, she began slacking off on her work, lazily cooking mostly potatoes along with whatever else she found in the kitchen. She has now all but abandoned her duties, doing the bare minimum and mostly immersing herself in her various crafty hobbies. With newfound interests in life, she takes on every new experience with the pure curiosity of a young girl.", "November 11", 162, "https://hololive.hololivepro.com/wp-content/uploads/2023/07/Cecilia-Immergreen_pr-img_01.png", "https://www.youtube.com/channel/UCvN5h1ShZtc7nly3pezRayg", "https://hololive.hololivepro.com/en/talents/cecilia-immergreen/", FALSE, "https://yt3.googleusercontent.com/A9zTWG0-UHX5Vd-gvKK21o1CGp4cDYPLflDCFHhl4Egs7YfeFfDnXoLIWdDoxDzdHdBGVZZf=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Gigi Murin", "Justice", "English", "June 22, 2024", "Born and raised under the flag of Freedom, Gigi Murin is a free-spirited Chaser and mischievous gremlin. While she is proficient in chasing down targets with pure intuition, she struggles with memorizing directions and making calculated decisions. She states that she'd rather not spend much time thinking because it makes her head hurt. These quirks are also present in her everyday life, where she tends to prioritize her instinctual craving for fun and being silly over anything else. She is often the source of headaches for those around her, causing trouble because she 'thought it would be funny.'", "October 18", 153, "https://hololive.hololivepro.com/wp-content/uploads/2023/07/Gigi-Murin_pr-img_01.webp", "https://www.youtube.com/channel/UCDHABijvPBnJm7F-KlNME3w", "https://hololive.hololivepro.com/en/talents/gigi-murin/", FALSE, "https://yt3.googleusercontent.com/iBaGLA10FOOPnKA8dJP-KYJJW099KsNFrZEgjWH-8IBTArRVsm455XrcSAZdxT9ev7xHdrL4z7o=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Raora Panthera", "Justice", "English", "June 23, 2024", "The Artist with the God Eyes, Raora Panthera is endowed with investigative and descriptive prowess. Her means of information gathering are diverse, utilizing not only her agility and social skills, but also various social media platforms and other… unique methods. The facial composites she draws based on the information she gathers are renowned for their accuracy, almost as if she was looking directly at the criminals as she draws. However, these days, her gaze is directed towards finding new pizza joints and enjoying the pop culture of the far east.", "May 11", 155, "https://hololive.hololivepro.com/wp-content/uploads/2023/07/Raora-Panthera_pr-img_01.png", "https://www.youtube.com/channel/UCl69AEx4MdqMZH7Jtsm7Tig", "https://hololive.hololivepro.com/en/talents/raora-panthera/", FALSE, "https://yt3.googleusercontent.com/hNHOvhRob-6Rt4EecYeleebwRmHzaXhE0hoSvdCWJvqBHqdlLCosuEyU0K5sVXSkVfazzTRx=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj");

-- ID Area 15 (Gen 1)
-- INSERT INTO vtubers(name, generation, branch, debut_date, description, birthday, height, img_url, youtube, hololive_url, graduated, banner_url)
-- VALUES ("Moona Hoshinova", "Area 15", "Indonesia", "April 11, 2020", "A college girl who works as a model and idol, but later got interested to become a VTuber too. On some rare occasion, Moona's stream might be visited by Moona's 'another personality', Hoshinova. That has deeper big sister-like voices and sadistic tendesion. Pay attention to her streams to meet Hoshinova!", "February 15", 165, "https://hololive.hololivepro.com/wp-content/uploads/2020/07/Moona-Hoshinova_pr-img_01.png", "https://www.youtube.com/channel/UCP0BspO_AMEe3aQqqpo89Dg", "https://hololive.hololivepro.com/en/talents/moona-hoshinova/", FALSE, "https://yt3.googleusercontent.com/KkXdJeSV62RLefnd4n6R15dhEkBRhjq8ykfEEaUamkYwPBRvul3Ujv0FvtrnH66nbVO4yISt_A=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Airani Iofifteen", "Area 15", "Indonesia", "April 12, 2020", "An alien princess who ran away from home and come to the earth and fell in love with earth’s culture, sometimes like to tease the viewers and being a nice iomama if her fans needs it. Sometimes got crazy over gacha game.", "July 15", 150, "https://hololive.hololivepro.com/wp-content/uploads/2020/07/Airani-Iofifteen_pr-img_01.png", "https://www.youtube.com/channel/UCAoy6rzhSf4ydcYjJw3WoVg", "https://hololive.hololivepro.com/en/talents/airani-iofifteen/", FALSE, "https://yt3.googleusercontent.com/CFpM3g1n4yf_ryDtQDcLtKDRFAGxii3eUeog9MYCr_kqiKohfwyjuYrUZPXRYz7y_O46OUC3kA=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Ayunda Risu", "Area 15", "Indonesia", "April 10, 2020", "A squirrel girl from a magical forest. She was lost in the human world, but due to certain circumstances, she ends up living in the home of a kind older sister. To return the favor, she decides to become a VTuber. Risu act, most of the time, just like a squirrel she is. She loves to do subtle pranks on people, shy with new people, and love to tease her viewer. Her laugh is also one of her unique characterictic.", "January 15", 153, "https://hololive.hololivepro.com/wp-content/uploads/2020/07/Ayunda-Risu_pr-img_01.png", "https://www.youtube.com/channel/UCOyYb1c43VlX9rc_lT6NKQw", "https://hololive.hololivepro.com/en/talents/ayunda-risu/", FALSE, "https://pbs.twimg.com/profile_banners/1234752200145899520/1723789896/1080x360");

-- ID Holoro (Gen 2)
-- INSERT INTO vtubers(name, generation, branch, debut_date, description, birthday, height, img_url, youtube, hololive_url, graduated, banner_url)
-- VALUES ("Anya Melfissa", "Holoro", "Indonesia", "December 5, 2020", "An ancient weapon known as 'Keris', she was granted human form through a mystical ritual performed by her master. She's just about always sleeping or playing games. Living mostly alone for so long has made her tend to be apathetic towards things and people she's uninterested in, but when talking about things she likes, she can be quite childlike and passionate. Her base personality is actually apathetic, especially towards humans. Don't let looks fool you - that's what every foolish human always does to themselves somehow.", "March 12", 147, "https://hololive.hololivepro.com/wp-content/uploads/2020/07/Anya-Melfissa_pr-img_01.png", "https://www.youtube.com/channel/UC727SQYUvx5pDDGQpTICNWg", "https://hololive.hololivepro.com/en/talents/anya-melfissa/", FALSE, "https://cdnb.artstation.com/p/assets/images/images/033/941/447/large/michael-angelo-lee-anyamelfissa-01.jpg?1610984164"),
-- ("Kureiji Ollie", "Holoro", "Indonesia", "December 4, 2020", "A zombie high school girl risen from her grave. She headed home, relying on memories retained from when she was still alive. Upon arriving, she discovered it had turned into a ramen shop! And so, in order to reclaim her house, she decided to become a VTuber. Ollie has a very big tendency to scream. Always lower your volumes during her streams.", "October 13", 162, "https://hololive.hololivepro.com/wp-content/uploads/2020/07/Kureiji-Ollie_pr-img_01.png", "https://www.youtube.com/channel/UCYz_5n-uDuChHtLo7My1HnQ", "https://hololive.hololivepro.com/en/talents/kureiji-ollie/", FALSE, "https://yt3.googleusercontent.com/RrSQcWKgnUWc6d5er-RJTZv_6I6PD8635RYKnkUyMJDio7pnAVN1HlS20SYzWCHoO26z7Q_6dg=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Pavolia Reine", "Holoro", "Indonesia", "December 6, 2020", "Lady of the Peafowl. While studying at a magic academy, she was involved in an incident and transferred to the human world. Since then, she has been unable to use much of her magic. Very fond of sweets, but weak with overly spicy food. At first glance, she seems to be the elegant type, but people who spend some more time with her will find out that she has more of a dorky personality. To quite a number of viewers, her laugh has been perceived as similar to a car engine starting.", "September 9", 172, "https://hololive.hololivepro.com/wp-content/uploads/2020/07/Pavolia-Reine_pr-img_01.png", "https://www.youtube.com/channel/UChgTyjG-pdNvxxhdsXfHQ5Q", "https://hololive.hololivepro.com/en/talents/pavolia-reine/", FALSE, "https://pbs.twimg.com/profile_banners/1328275136575799297/1758259208/1080x360");

-- ID HoloH3ro (Gen 3)
-- INSERT INTO vtubers(name, generation, branch, debut_date, description, birthday, height, img_url, youtube, hololive_url, graduated, banner_url)
-- VALUES ("Kobo Kanaeru", "HoloH3ro", "Indonesia", "March 27, 2022", "A carefree girl who lives in the topmost room of a lighthouse, she is actually the bloodline of the strongest rain shaman in the area. She has great potential to control rain, but she does not like to do it as a task. In order to win back her Rain Master title, she needs to prove to her family that she can keep their rain shaman service afloat. Not only does she have to train daily, but she also needs to adopt some sort of virtual marketing strategy to succeed!", "December 12", 150, "https://hololive.hololivepro.com/wp-content/uploads/2020/07/Kobo-Kanaeru_pr-img_01.png", "https://www.youtube.com/channel/UCjLEmnpCNeisMxy134KPwWw", "https://hololive.hololivepro.com/en/talents/kobo-kanaeru/", FALSE, "https://yt3.googleusercontent.com/HkdBYiIHoZdS3jhzfTtLCAf6upeuzDb_yNeMyMi4fH3JGh57C-S1leqJG2VksyUTpPPKE2jcRSk=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Kaela Kovalskia", "HoloH3ro", "Indonesia", "March 26, 2022", "After taking over her great blacksmithing teacher's forge, she felt a lack of excitement in her life. So, she decided to be free and depart on a journey to find rare smithing materials, one of which was rumored to be under the building of a certain 'idol group' in town. She also loves challenging herself and has a peculiar taste when it comes to foods!", "August 30", 173, "https://hololive.hololivepro.com/wp-content/uploads/2020/07/Kaela-Kovalskia_pr-img_02.png", "https://www.youtube.com/channel/UCZLZ8Jjx_RN2CXloOmgTHVg", "https://hololive.hololivepro.com/en/talents/kaela-kovalskia/", FALSE, "https://yt3.googleusercontent.com/JhknNUVHVa8KZ9zxZ0MGMi3pV3BevLvL1TQNVUCZU9MlKLnH20rU1-ZF_zXCRiuP29ye3U24d5w=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj"),
-- ("Vestia Zeta", "HoloH3ro", "Indonesia", "March 25, 2022", "She is the mysterious 7th recruit of The Secret Archive Unit that has a full license to collect virtual data. Despite her being a promising rookie, who is also known as codename V.7, she turns clumsy when things are not going exactly according to the manual. It was initially a lonely mission to infiltrate the virtual world, but now she had found comfort here. Will this mission end up leading her to a new destiny instead...?", "November 7", 155, "https://hololive.hololivepro.com/wp-content/uploads/2020/07/Vestia-Zeta_pr-img_01.png", "https://www.youtube.com/channel/UCTvHWSfBZgtxE4sILOaurIQ", "https://hololive.hololivepro.com/en/talents/vestia-zeta/", FALSE, "https://yt3.googleusercontent.com/CC8vsiTQUF_14W3YShXYHudJZJSUMgmsn46RBO5Yj2W_vMYvv0Aa5XqbdRFGag6nq5QvmnCZsKE=w1707-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj");

